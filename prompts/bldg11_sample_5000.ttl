            sh:nodeKind sh:IRI ;
            sh:path rec:relatedTo ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:name "closed time"^^xsd:string ;
            sh:path rec:closedTime ],
        [ a sh:PropertyShape ;
