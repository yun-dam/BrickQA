            sh:maxCount 1 ;
            sh:name "created by"^^xsd:string ;
            sh:nodeKind sh:IRI ;
            sh:path rec:createdBy ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:name "created time"^^xsd:string ;
            sh:path rec:createdTime ],
        [ a sh:PropertyShape ;
            sh:minCount 1 ;
