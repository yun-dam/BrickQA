            sh:predicate brick:hasTag ;
            sh:subject sh:this ] ;
    brick:hasAssociatedTag tag:Electric,
        tag:Point,
        tag:Power,
        tag:Real,
        tag:Sensor ;
    brick:hasQuantity qudtqk:ActivePower .

